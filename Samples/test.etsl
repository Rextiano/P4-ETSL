log "--- STARTING ETSL IMMUTABLE TEST SUITE ---";

// ==========================================
// TEST FRAMEWORK
// ==========================================
int passed = 0;
int failed = 0;

function assertEqual(int actual, int expected, string name) {
if (actual == expected) then {
log "PASS: " + name;
passed = passed + 1;
}
if (actual != expected) then {
log "FAIL: " + name;
log "Expected: " + expected;
log "Got: " + actual;
failed = failed + 1;
}
}

function assertTrue(bool cond, string name) {
if (cond) then {
log "PASS: " + name;
passed = passed + 1;
}
if (cond == false) then {
log "FAIL: " + name;
failed = failed + 1;
}
}

// ==========================================
// 1. BASIC MATH
// ==========================================
assertEqual(10 + 5, 15, "Addition");
assertEqual(10 - 5, 5, "Subtraction");
assertEqual(4 * 5, 20, "Multiplication");
assertEqual(20 / 4, 5, "Division");

int prec = (2 + 3) * 4;
assertEqual(prec, 20, "Precedence");

// ==========================================
// 2. COMPARISONS
// ==========================================
assertTrue(5 > 2, ">");
assertTrue(2 < 5, "<");
assertTrue(5 >= 5, ">=");
assertTrue(5 <= 5, "<=");
assertTrue(5 == 5, "==");
assertTrue(5 != 3, "!=");

// ==========================================
// 3. STRINGS
// ==========================================
string s = "ETSL";
assertTrue(s == "ETSL", "String equality");

// ==========================================
// 4. FUNCTIONS (PASS-BY-VALUE)
// ==========================================
function square(int x) {
return x * x;
}
assertEqual(square(6), 36, "Function return");

// Ensure input not modified
int val = 10;
function testVal(int x) {
int y = x + 5;
return y;
}
testVal(val);
assertEqual(val, 10, "Pass-by-value immutability");

// ==========================================
// 5. SCOPING & SHADOWING
// ==========================================
int x = 10;

function shadowTest(int x) {
int y = x + 5;
return y;
}
assertEqual(shadowTest(5), 10, "Parameter shadowing");
assertEqual(x, 10, "Outer scope unchanged");

// Block scope
int outer = 100;
if (outer == 100) then {
int outer = 200;
}
assertEqual(outer, 100, "Block scope isolation");

// ==========================================
// 6. RECURSION
// ==========================================
function fact(int n) {
if (n <= 1) then {
return 1;
}
return n * fact(n - 1);
}
assertEqual(fact(5), 120, "Recursion");

// ==========================================
// 7. STRING CONCAT
// ==========================================
string a = "Hello ";
string b = "World";
string c = a + b;
assertTrue(c == "Hello World", "String concat");

// ==========================================
// SUMMARY
// ==========================================
log "--- RESULTS ---";
log "Passed: " + passed;
log "Failed: " + failed;

// ==========================================
// 8. NEGATIVE TESTS (RUN SEPARATELY)
// ==========================================

// --- IMMUTABILITY (should crash)
// int a = 5;
// a = 10;

// --- REDECLARATION (should crash)
// int b = 5;
// int b = 10;

// --- UNDEFINED VARIABLE (should crash)
// log z;

// --- DIVISION BY ZERO (should crash)
// int d = 5 / 0;
